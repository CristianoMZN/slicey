# URL base do backend (Fastify/Bun/etc)
VITE_API_BASE_URL=http://localhost:3000

# true  -> usa fallback em mock no frontend
# false -> usa backend real pelos services
VITE_USE_MOCK_API=true

# Opcional: se preenchida, o frontend usa esta chave VAPID sem buscar no backend
VITE_PUSH_PUBLIC_VAPID_KEY=
