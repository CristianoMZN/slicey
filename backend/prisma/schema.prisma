generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  MANAGER
  ADMIN
}

enum UserType {
  CUSTOMER
  CREATOR
}

enum MediaType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  nickname  String   @unique
  role      UserRole @default(USER)
  type      UserType @default(CUSTOMER)

  profile          Profile?
  posts            Post[]
  sessions  Session[]
  comments         Comment[]
  interactions     Interaction[]
  sentMessages     DirectMessage[] @relation("SentMessages")
  receivedMessages DirectMessage[] @relation("ReceivedMessages")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id])
  publicName   String
  slug         String   @unique
  bio          String?
  profileImage String?
  coverImage   String?
  services     String?
  isPublic     Boolean  @default(true)
  fullName     String
  cpf          String   @unique
  birthDate    DateTime
  pixKey       String?
  bankAccount  Json?
  address      Json?
  updatedAt    DateTime @updatedAt
}

model Post {
  id            Int       @id @default(autoincrement())
  authorId      Int
  author        User      @relation(fields: [authorId], references: [id])
  type          MediaType
  content       String?   @db.Text
  mediaUrl      String?
  duration      Int?
  location      String?
  allowComments Boolean   @default(true)
  comments      Comment[]
  interactions  Interaction[]
  createdAt     DateTime  @default(now())
}

model Interaction {
  id          Int       @id @default(autoincrement())
  postId      Int
  userId      Int
  type        String
  geoLocation String?
  canceledAt  DateTime?
  createdAt   DateTime  @default(now())

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([postId, userId, type])
}

model Comment {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  text      String   @db.Text
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model DirectMessage {
  id         Int       @id @default(autoincrement())
  senderId   Int
  receiverId Int
  type       MediaType
  content    String?   @db.Text
  mediaUrl   String?
  sentAt     DateTime  @default(now())
  readAt     DateTime?

  sender   User @relation("SentMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model Place {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  latitude    Float
  longitude   Float
  geoLocations GeoLocation[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Session {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
}

model GeoLocation {
  id        Int      @id @default(autoincrement())
  placeId   Int
  distance  Float
  createdAt DateTime @default(now())

  place     Place    @relation(fields: [placeId], references: [id])
}